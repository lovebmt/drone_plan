{
  "name": "uav-manufacturing-slides",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "slidev --open",
    "build": "slidev build",
    "build:pages": "slidev build --base /drone_plan/ --out dist-pages",
    "export": "slidev export --output dist/UAV-Manufacturing-Complex.pdf",
    "render:images": "npm run build:pages && node scripts/render-images.mjs",
    "images:pdf": "node scripts/images-to-pdf.mjs",
    "export:rendered": "npm run render:images && npm run images:pdf"
  },
  "devDependencies": {
    "@slidev/cli": "^52.15.0",
    "@slidev/theme-default": "^0.25.0",
    "playwright-chromium": "^1.59.1"
  },
  "dependencies": {
    "mermaid": "^11.14.0"
  }
}
